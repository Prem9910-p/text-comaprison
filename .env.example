# Optional: set your production site origin (no trailing slash) so canonical,
# Open Graph, Twitter, and JSON-LD URLs resolve to absolute URLs at build time.
# Example: https://textcompare.example.com
# Leave empty for relative URLs during local development.
VITE_SITE_ORIGIN=

# Google AdSense configuration
# Example:
# VITE_ADSENSE_CLIENT_ID=ca-pub-1234567890123456
# VITE_ADSENSE_TOP_SLOT_ID=1234567890
# VITE_ADSENSE_BOTTOM_SLOT_ID=0987654321
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_TOP_SLOT_ID=
VITE_ADSENSE_BOTTOM_SLOT_ID=

# Optional video ad embed URL (for networks that provide iframe video creatives)
# Example: https://ads.example.com/video-placement?id=abc123
VITE_VIDEO_AD_URL=
